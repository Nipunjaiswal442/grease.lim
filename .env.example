# Convex (set automatically by `npx convex dev`, or by `npx convex deploy` for production)
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Firebase — get from Firebase Console > Project Settings > Your Apps
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# NVIDIA AI — get from build.nvidia.com > API Keys
VITE_NVIDIA_API_KEY=nvapi-...
