# Convex (set automatically by `npx convex dev`, or by `npx convex deploy` for production)
VITE_CONVEX_URL=https://your-deployment.convex.cloud
# Optional alias used by the Next.js implementation guide.
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Firebase — get from Firebase Console > Project Settings > Your Apps
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef
# Optional aliases used by the Next.js implementation guide.
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef

# NVIDIA AI — get from build.nvidia.com > API Keys
# Preferred for Vercel and local dev proxy; keep this server-side.
NVIDIA_API_KEY=nvapi-...

# Optional one-time seed guard for deployments that expose a seed route.
SEED_SECRET=change-me

# Legacy local fallback supported by the Vite dev proxy if already configured.
# Do not add this as a public Vercel client variable for new deployments.
VITE_NVIDIA_API_KEY=
